# Copy this file to .env and paste your Resend details.
RESEND_API_KEY=re_your_api_key_here

# Local testing: use Resend's test sender (required until you verify your own domain).
RESEND_FROM_EMAIL="Your Academy Name <onboarding@resend.dev>"

# Production: verify your domain at https://resend.com/domains, then use e.g.:
# RESEND_FROM_EMAIL="Your Academy Name <hello@yourdomain.com>"
